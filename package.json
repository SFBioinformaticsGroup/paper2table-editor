{
  "name": "tables-editor",
  "version": "0.0.2",
  "private": true,
  "main": "out/main/index.js",
  "author": {
    "name": "Franco Leonardo Bulgarelli",
    "email": "franco@mumuki.org"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "electron:download": "node node_modules/electron/install.js",
    "dist": "electron-vite build && electron-builder --publish never",
    "dist:linux": "electron-vite build && electron-builder --linux --publish never",
    "dist:win": "electron-vite build && electron-builder --win --publish never",
    "dist:dir": "electron-vite build && electron-builder --dir"
  },
  "dependencies": {
    "ajv": "^8.17.0",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.4.0",
    "vite": "^7.0.0",
    "vitest": "^4.1.8"
  }
}
