{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tables File",
  "type": "object",
  "properties": {
    "tables": {
      "type": "array",
      "items": {
        "type": "object",
        "oneOf": [
          {
            "properties": {
              "rows": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/row"
                }
              },
              "page": {
                "type": "integer"
              }
            },
            "required": [
              "rows",
              "page"
            ],
            "additionalProperties": false
          },
          {
            "properties": {
              "table_fragments": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "rows": {
                      "type": "array",
                      "items": {
                        "$ref": "#/$defs/row"
                      }
                    },
                    "page": {
                      "type": "integer"
                    }
                  },
                  "required": [
                    "rows",
                    "page"
                  ],
                  "additionalProperties": false
                }
              }
            },
            "required": [
              "table_fragments"
            ],
            "additionalProperties": false
          }
        ]
      }
    },
    "citation": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/valueWithAgreement"
          }
        }
      ]
    },
    "metadata": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "properties": {
            "filename": {
              "type": "string"
            },
            "curations": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/curation"
              }
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "uuid": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string"
        }
      ]
    }
  },
  "additionalProperties": false,
  "$defs": {
    "curation": {
      "type": "object",
      "properties": {
        "curator": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "timestamp": {
          "type": "string"
        }
      },
      "required": ["curator"],
      "additionalProperties": false
    },
    "valueWithAgreement": {
      "type": "object",
      "properties": {
        "value": {
          "type": "string"
        },
        "agreement_level": {
          "type": "integer"
        }
      },
      "required": [
        "value",
        "agreement_level"
      ],
      "additionalProperties": false
    },
    "columnValue": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/valueWithAgreement"
          }
        }
      ]
    },
    "row": {
      "type": "object",
      "properties": {
        "agreement_level_": {
          "oneOf": [
            {"type": "null"},
            {"type": "integer"}
          ]
        },
        "sources_": {
          "oneOf": [
            {"type": "null"},
            {"type": "array", "items": {"type": "string"}}
          ]
        },
        "row_": {
          "oneOf": [
            {"type": "null"},
            {"type": "integer"}
          ]
        }
      },
      "patternProperties": {
        "^.*[^_]$": {
          "$ref": "#/$defs/columnValue"
        }
      },
      "additionalProperties": false
    }
  }
}
